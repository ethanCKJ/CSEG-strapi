{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(npm run build:*)",
      "Bash(npm run develop:*)",
      "Bash(while read file)",
      "Bash(do)",
      "Bash(if ! grep -q \"import { styled } from.*utils/styled\" \"$file\")",
      "Bash(then)",
      "Bash(echo:*)",
      "Bash(fi)",
      "Bash(done)",
      "Bash(node add-styled-imports.js:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(xargs:*)"
    ]
  }
}
