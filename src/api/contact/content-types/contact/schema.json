{
  "kind": "collectionType",
  "collectionName": "contacts",
  "info": {
    "singularName": "contact",
    "pluralName": "contacts",
    "displayName": "Contact messages"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "maxLength": 100
    },
    "subject": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "message": {
      "type": "text",
      "required": true
    },
    "resolved": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "privateNotes": {
      "type": "text",
      "private": true,
      "required": false
    }
  }
}
