{
  "kind": "collectionType",
  "collectionName": "research_projects",
  "info": {
    "singularName": "research-project",
    "pluralName": "research-projects",
    "displayName": "Research projects"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "required": true,
      "unique": false
    },
    "summary": {
      "type": "text",
      "maxLength": 1200,
      "required": true
    },
    "primaryInvestigator": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "coInvestigator": {
      "type": "string",
      "maxLength": 200,
      "required": false
    },
    "projectPageCoverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "projectStartDate": {
      "type": "date",
      "required": true
    },
    "ongoingProject": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "projectEndDate": {
      "type": "date",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "ongoingProject"
            },
            false
          ]
        }
      },
      "required": true
    },
    "primaryInvestigatorEmail": {
      "type": "string",
      "required": true
    },
    "coInvestigatorEmail": {
      "type": "string"
    },
    "research_topics": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-tag.event-tag",
      "mappedBy": "research_projects"
    },
    "projectPageContent": {
      "type": "richtext",
      "required": true
    },
    "markdownTemplateDocs": {
      "type": "customField",
      "customField": "plugin::documentation-viewer.doc-viewer",
      "options": {
        "documentId": "gprskf4rmcwx3fgzfaah77l2",
        "type": "accordion"
      }
    }
  }
}
