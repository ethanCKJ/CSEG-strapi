{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "required": true,
      "unique": true
    },
    "eventDate": {
      "type": "date",
      "required": true
    },
    "eventStartTime": {
      "type": "time",
      "required": true
    },
    "eventEndTime": {
      "type": "time",
      "required": true
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "speaker": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "summary": {
      "type": "text",
      "maxLength": 250
    },
    "eventPage": {
      "type": "blocks",
      "required": true
    },
    "event_type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event-type.event-type",
      "inversedBy": "events"
    },
    "event_tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-tag.event-tag",
      "mappedBy": "events"
    },
    "publicEvent": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "open_to": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::member-type.member-type",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "publicEvent"
            },
            true
          ]
        }
      },
      "inversedBy": "events"
    },
    "emailSubject": {
      "type": "string",
      "default": "Untitled subject",
      "required": true
    },
    "emailBody": {
      "type": "text",
      "private": true,
      "default": "Untitled body",
      "required": true
    },
    "emailTarget1": {
      "type": "email",
      "private": true,
      "required": true,
      "default": "mailing-list@example.com"
    },
    "emailTarget2": {
      "type": "email",
      "private": true
    },
    "emailTarget3": {
      "type": "email",
      "private": true
    },
    "emailTarget4": {
      "type": "email",
      "private": true
    },
    "emailCount": {
      "type": "integer",
      "private": true,
      "required": true,
      "default": 0
    }
  }
}
