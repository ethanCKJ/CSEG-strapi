{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "required": true,
      "unique": true
    },
    "eventDate": {
      "type": "date",
      "required": true
    },
    "eventStartTime": {
      "type": "time",
      "required": true
    },
    "eventEndTime": {
      "type": "time",
      "required": true
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "required": false
    },
    "speaker": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "event_tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-tag.event-tag",
      "mappedBy": "events"
    },
    "publicEvent": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "open_to": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::member-type.member-type",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "publicEvent"
            },
            true
          ]
        }
      },
      "inversedBy": "events"
    },
    "emailSubject1": {
      "type": "string",
      "private": true,
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "showEmailFields"
            },
            true
          ]
        }
      },
      "required": false
    },
    "emailBody1": {
      "type": "text",
      "private": true,
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "showEmailFields"
            },
            true
          ]
        }
      },
      "required": false
    },
    "emailCount": {
      "type": "integer",
      "private": true,
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "showEmailFields"
            },
            true
          ]
        }
      },
      "required": false,
      "default": 0
    },
    "privateNotes": {
      "type": "text",
      "private": true
    },
    "eventType": {
      "type": "enumeration",
      "required": true,
      "default": "Teaching Hour",
      "enum": [
        "Teaching Hour",
        "Reading Group",
        "Workshop",
        "Big Event",
        "Other"
      ]
    },
    "eventPage": {
      "type": "richtext",
      "required": true
    },
    "emailInstructions": {
      "type": "customField",
      "customField": "plugin::documentation-viewer.doc-viewer",
      "options": {
        "documentId": "gprskf4rmcwx3fgzfaah77l2",
        "isAccordion": true
      }
    },
    "emailSubject2": {
      "type": "string",
      "private": true,
      "conditions": {
        "visible": {
          "==": [
