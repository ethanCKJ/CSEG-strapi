{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "required": true,
      "unique": true
    },
    "eventDate": {
      "type": "date",
      "required": true
    },
    "eventStartTime": {
      "type": "time",
      "required": true
    },
    "eventEndTime": {
      "type": "time",
      "required": true
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "speaker": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "summary": {
      "type": "text",
      "maxLength": 250
    },
    "eventPage": {
      "type": "blocks",
      "required": true
    },
    "event_type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event-type.event-type",
      "inversedBy": "events"
    },
    "event_tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-tag.event-tag",
      "mappedBy": "events"
    },
    "publicEvent": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "open_to": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::member-type.member-type",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "publicEvent"
            },
            true
          ]
        }
      },
      "inversedBy": "events"
    },
    "emailSubject": {
      "type": "string",
      "default": "Untitled subject",
      "required": true
    },
    "emailBody": {
      "type": "text",
      "private": true,
      "default": "Untitled body",
      "required": true
    },
    "emailTarget1": {
      "type": "email",
      "private": true,
      "required": true,
      "default": "mailing-list@example.com"
    },
    "emailTarget2": {
      "type": "email",
      "private": true
    },
    "emailTarget3": {
      "type": "email",
      "private": true
    },
    "emailTarget4": {
      "type": "email",
      "private": true
    },
    "emailCount": {
      "type": "integer",
      "private": true,
      "required": false,
      "default": 0
    },
    "privateNotes": {
      "type": "text",
      "private": true
    },
    "emailRule1OrCustom": {
      "type": "enumeration",
      "default": "Send on day of event",
      "enum": [
        "Send on day of event",
        "Send 1 day before at 09:00",
        "Send 3 days before at 09:00",
        "Send 7 days before at 09:00",
        "No scheduled email",
        "Custom rule"
      ]
    },
    "emailRule2": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "emailRule1OrCustom"
            },
            "No scheduled email"
          ]
        }
      },
      "required": true,
      "default": "No scheduled email",
      "enum": [
        "No scheduled email",
        "Send on day of event",
        "Send 1 day before at 09:00",
        "Send 3 days before at 09:00",
        "Send 7 days before at 09:00"
      ]
    },
    "emailRule3": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "emailRule2"
            },
            "No scheduled email"
          ]
        }
      },
      "required": true,
      "default": "No scheduled email",
      "enum": [
        "No scheduled email",
        "Send on day of event",
        "Send 1 day before at 09:00",
        "Send 3 days before at 09:00",
        "Send 7 days before at 09:00"
      ]
    },
    "emailRule4": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "emailRule3"
            },
            "No scheduled email"
          ]
        }
      },
      "required": true,
      "default": "No scheduled email",
      "enum": [
        "No scheduled email",
        "Send on day of event",
        "Send 1 day before at 09:00",
        "Send 3 days before at 09:00",
        "Send 7 days before at 09:00"
      ]
    },
    "emailRule5": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "emailRule4"
            },
            "No scheduled email"
          ]
        }
      },
      "required": true,
      "enum": [
        "Send on day of event",
        "Send 1 day before at 09:00",
        "Send 3 days before at 09:00",
        "Send 7 days before at 09:00"
      ]
    },
    "sendTime": {
      "type": "time",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "emailRule1OrCustom"
            },
            "Custom rule"
          ]
        }
      },
      "required": true,
      "default": "09:00:00.000"
    },
    "emailRuleV2": {
      "type": "component",
      "component": "shared.email-rule",
      "repeatable": true
    },
    "daysBefore": {
      "type": "integer",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "emailRule1OrCustom"
            },
            "Custom rule"
          ]
        }
      },
      "required": true
    }
  }
}
