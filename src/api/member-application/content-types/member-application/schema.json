{
  "kind": "collectionType",
  "collectionName": "member_applications",
  "info": {
    "singularName": "member-application",
    "pluralName": "member-applications",
    "displayName": "MemberApplication"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true
    },
    "preferredName": {
      "type": "string",
      "required": false
    },
    "affiliations": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "aboutYou": {
      "type": "text"
    },
    "topics": {
      "type": "text",
      "required": true
    },
    "willingnessToVolunteer": {
      "type": "enumeration",
      "enum": [
        "yes-internally",
        "yes-externally",
        "no"
      ]
    },
    "approved": {
      "type": "boolean",
      "default": false
    }
  }
}
