{
  "kind": "collectionType",
  "collectionName": "member_applications",
  "info": {
    "singularName": "member-application",
    "pluralName": "member-applications",
    "displayName": "MemberApplication"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "preferredName": {
      "type": "string",
      "maxLength": 100,
      "required": false
    },
    "affiliations": {
      "type": "string",
      "maxLength": 200
    },
    "email": {
      "type": "email",
      "required": true,
      "maxLength": 100
    },
    "aboutYou": {
      "type": "text",
      "maxLength": 2000,
      "required": true
    },
    "topics": {
      "type": "text",
      "maxLength": 2000,
      "required": true
    },
    "applicationStatus": {
      "type": "enumeration",
      "private": true,
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    }
  }
}
